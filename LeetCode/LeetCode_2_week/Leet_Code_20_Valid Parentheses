class Solution:
    def isValid(self, s: str) -> bool:
        total = []
        pairs = {
            ")" : "(",
            "}" : "{",
            "]" : "["
        }

        for i in s: # iterate through each character in s
            if i not in pairs: # if i is an opening bracket (not in pairs keys)
                total.append(i) # push it onto the stack
            else:
                if not total: # if stack is empty, no matching opening bracket exists
                    return False
                
                top = total.pop() # pop the last element from the stack
                if pairs[i] != top: # if the popped bracket doesn't match the expected pair
                    return False
        return len(total) == 0 # if stack is empty, all brackets were matched correctly
