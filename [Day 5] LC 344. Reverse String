class Solution:
    def reverseString(self, s: List[str]) -> None:
        """
        Do not return anything, modify s in-place instead.
        """
        lefts = 0
        right = len(s) - 1

        while lefts < right:
            s[lefts], s[right] = s[right], s[lefts]

            lefts += 1
            right -= 1
